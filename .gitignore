# Python
__pycache__/
*.py[cod]
.pytest_cache/
.scrape_cache/
# Local virtualenv created by scripts/setup.sh / make setup.
.venv/
venv/
# Optional reproducible lockfile written by ``make freeze``.
requirements.lock.txt

# Node / Next
node_modules/
frontend/node_modules/
.next/
.next.new/
.next.old/
frontend/.next/
frontend/.next.new/
frontend/.next.old/
tests/e2e/playwright-report/
tests/e2e/test-results/
tests/e2e/tests/
test-results/

# Local tooling
.codex-loop/
.claude/

# Deploy state (when using local default path inside repo)
.deploy/

# Secrets / sessions / operator credentials
*_session.json
*.env
.env*
!.env.example
.secrets/

# Generated scraper outputs
dynasty_data.js
dynasty_data_*.json
CSVs/dynasty_full.csv
CSVs/dynasty_values.csv
data/
exports/
# ROS pipeline keeps the directory tree + manual mapping overrides
# in source control so a fresh checkout has the layout in place.
# Generated scrape outputs (CSVs, run JSONs, aggregate snapshots,
# sims, team-strength) stay gitignored under data/.
!data/ros/
data/ros/sources/*
!data/ros/sources/.gitkeep
data/ros/runs/*
!data/ros/runs/.gitkeep
data/ros/aggregate/*
!data/ros/aggregate/.gitkeep
data/ros/team_strength/*
!data/ros/team_strength/.gitkeep
data/ros/sims/*
!data/ros/sims/.gitkeep
!data/ros/mapping_overrides.json

# Temporary sync artifacts (created by sync.bat or manual operations)
tmp_sync_*/

# Optional local artifacts
*.log
*.tmp
.DS_Store
Thumbs.db
*.xlsx
!CSVs/Draft Data.xlsx
