# Environment variables for the dynasty trade-calculator stack.

# Frontend URL — Next.js is the sole frontend (Static removed).
FRONTEND_URL=http://127.0.0.1:3000

# Canonical Sleeper league IDs used by Dynasty Scraper.py.
# Backend is the source of truth; frontend reads from backend payload.
SLEEPER_LEAGUE_ID=1312006700437352448
BASELINE_LEAGUE_ID=1328545898812170240

# Sleeper league trade-history rolling window (days).
# Default is 365 (one full rolling year).
SLEEPER_TRADE_HISTORY_DAYS=365

# Private-use Jason app gate
JASON_LOGIN_USERNAME=jasonleetucker
# REQUIRED: server will not start without this set
JASON_LOGIN_PASSWORD=changeme
# Set to false only for local HTTP dev (defaults to true for production safety)
JASON_AUTH_COOKIE_SECURE=true

# R-10: Minimum free disk space (MB) before skipping data file writes
DISK_SPACE_MIN_MB=500

# R-8: Log format — "text" for human-readable (default), "json" for structured log aggregation
LOG_FORMAT=text

# Uptime watchdog configuration
# UPTIME_CHECK_ENABLED=true
# UPTIME_CHECK_URL=https://riskittogetthebrisket.org/api/health
# UPTIME_CHECK_INTERVAL_SEC=300
# UPTIME_CHECK_TIMEOUT_SEC=5
# UPTIME_ALERT_FAIL_THRESHOLD=2


# Email alerting (all required for alerts to work)
# ALERT_ENABLED=true
# ALERT_TO=you@example.com
# ALERT_FROM=sender@gmail.com
# ALERT_PASSWORD=gmail-app-password

# ── IDP Calibration Lab ──────────────────────────────────────────────────
# Controls network access for the historical stats adapter layer at
# src/idp_calibration/stats_adapter.py.
#
# Default behaviour:
#   * Production server (no pytest in sys.modules)   → network ENABLED
#   * Unit-test / pytest run                         → network DISABLED
#
# Override only if you need to pin the behaviour — e.g. you want to
# disable network on the prod host (use "0"), or force it on in a
# local dev workflow (use "1").
#
# Accepted values:
#   enable:  "1" / "true" / "yes" / "on"
#   disable: "0" / "false" / "no" / "off"
#
# IDP_CALIBRATION_ALLOW_NETWORK=1
