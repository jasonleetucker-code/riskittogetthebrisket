# Optional environment variables for new canonical pipeline scaffolding.
# Existing app runtime remains unchanged.

# Frontend runtime authority for server.py.
# static = serve Static/index.html intentionally (production default)
# next   = require Next proxy only (no silent static fallback)
# auto   = try Next, then explicit static fallback with status reporting
FRONTEND_RUNTIME=static
FRONTEND_URL=http://127.0.0.1:3000
# Legacy toggle (deprecated): ENABLE_NEXT_FRONTEND_PROXY=true|false

# If set, source pull/canonical scripts write outputs under this directory.
# If omitted, scripts default to <repo>/data
# CANONICAL_DATA_DIR=C:\path\to\Trade Calculator\data

# Optional default league profile file for league refresh script.
# LEAGUE_PROFILE_PATH=config/leagues/default_superflex_idp.template.json

# Canonical Sleeper league IDs used by Dynasty Scraper.py.
# Backend is the source of truth; frontend reads from backend payload.
SLEEPER_LEAGUE_ID=1312006700437352448
BASELINE_LEAGUE_ID=1328545898812170240

# Scrape automation policy (conservative defaults).
# Full scrape cadence is intentionally slower than lightweight health checks.
SCRAPE_STARTUP_ENABLED=true
SCRAPE_SCHEDULER_ENABLED=true
SCRAPE_INTERVAL_HOURS=4
SCRAPE_INTERVAL_JITTER_MINUTES=10
SCRAPE_FAILURE_BACKOFF_MINUTES=60
SCRAPE_MAX_BACKOFF_HOURS=12
MAX_HEALTHY_SCRAPE_AGE_HOURS=10

# Sleeper league trade-history rolling window (days).
# Default is 365 (one full rolling year).
SLEEPER_TRADE_HISTORY_DAYS=365

# Private-use Jason app gate
JASON_LOGIN_USERNAME=jasonleetucker
# Required for private /app, /rankings, /trade authentication.
# No insecure fallback is provided by server.py when unset.
JASON_LOGIN_PASSWORD=change-this-before-use
JASON_AUTH_COOKIE_SECURE=false

# Uptime watchdog automation.
# Leave enabled in production so server can self-report outages.
UPTIME_CHECK_ENABLED=true
UPTIME_CHECK_URL=https://riskittogetthebrisket.org/api/health
UPTIME_CHECK_INTERVAL_SEC=300
UPTIME_CHECK_TIMEOUT_SEC=5
UPTIME_ALERT_FAIL_THRESHOLD=2
