# Optional environment variables for new canonical pipeline scaffolding.
# Existing app runtime remains unchanged.

# If set, source pull/canonical scripts write outputs under this directory.
# If omitted, scripts default to <repo>/data
# CANONICAL_DATA_DIR=C:\path\to\Trade Calculator\data

# Optional default league profile file for league refresh script.
# LEAGUE_PROFILE_PATH=config/leagues/default_superflex_idp.template.json

